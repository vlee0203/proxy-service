apiVersion: apps/v1
kind: Deployment
metadata:
  annotations:
    deploy.cloud.sealos.io/maxReplicas: "1"
    deploy.cloud.sealos.io/minReplicas: "1"
    originImageName: ghcr.io/vlee0203/proxy-service:IMAGE_TAG
  labels:
    app: dify-marketplace-proxy
    cloud.sealos.io/app-deploy-manager: dify-marketplace-proxy
  name: dify-marketplace-proxy
spec:
  progressDeadlineSeconds: 600
  replicas: 1
  revisionHistoryLimit: 1
  selector:
    matchLabels:
      app: dify-marketplace-proxy
  strategy:
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: dify-marketplace-proxy
    spec:
      automountServiceAccountToken: false
      containers:
        - name: dify-marketplace-proxy
          image: ghcr.io/vlee0203/proxy-service:IMAGE_TAG
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 8080
              protocol: TCP
          env:
            - name: TARGET
              value: "{{ .target }}"
            - name: HTTPS_PROXY
              value: "{{ .httpsProxy }}"
          resources:
            limits:
              cpu: "1"
              memory: 1Gi
            requests:
              cpu: 100m
              memory: 102Mi
---
apiVersion: v1
kind: Service
metadata:
  labels:
    cloud.sealos.io/app-deploy-manager: dify-marketplace-proxy
  name: dify-marketplace-proxy
spec:
  ports:
    - name: http
      port: 8080
      protocol: TCP
      targetPort: 8080
  selector:
    app: dify-marketplace-proxy
  type: ClusterIP

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  annotations:
    kubernetes.io/ingress.class: nginx
    nginx.ingress.kubernetes.io/cors-allow-headers: Content-Type, Authorization, X-Dify-Version
    nginx.ingress.kubernetes.io/cors-allow-methods: GET, POST, PUT, DELETE, OPTIONS
    nginx.ingress.kubernetes.io/cors-allow-origin: '*'
    nginx.ingress.kubernetes.io/cors-max-age: "600"
    nginx.ingress.kubernetes.io/enable-cors: "true"
  labels:
    cloud.sealos.io/app-deploy-manager: dify-marketplace-proxy
    cloud.sealos.io/app-deploy-manager-domain: dify-marketplace-proxy
  name: dify-marketplace-proxy
spec:
  rules:
    # {{ .cloudDomain }} 由 sealos run 时用 ENV 渲染（sealos run --env cloudDomain=<域名>）。
    - host: dify-marketplace-proxy.{{ .cloudDomain }}
      http:
        paths:
          - backend:
              service:
                name: dify-marketplace-proxy
                port:
                  number: 8080
            path: /
            pathType: Prefix
  tls:
    - hosts:
        - dify-marketplace-proxy.{{ .cloudDomain }}
      secretName: wildcard-cert
